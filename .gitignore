# 全てのファイルを一度、無視
/*

# さらに、ドットから始まる設定ファイルを無視
/.*

# "無視したくないファイル"は以下に"![ファイル名]"で指定
##### Gitで管理するファイルリスト #####
!/bin

!/.gitignore
!/.gitconfig
!/.gitmodules

!/.zshrc
!/.fzf.zsh

!/.tmux.conf

!/.config

!/.Brewfile

!/.claude
!/tmux

# 上記に"無視したくないファイル"としてリスト化した中から、さらに"無視したいファイル"を指定
/.config/anyenv
/.config/Autodesk
/.config/configstore
/.config/efm-langserver
/.config/flutter
/.config/gatsby
/.config/github-copilot
/.config/Unreal Engine
/.config/NuGet
/.config/stetic
/.config/tool_state
/.config/xbuild
/.config/yarn
/.config/analog.com
/.config/gcloud
/.config/gtk-3.0
/.config/karabiner
/.config/Unreal Engine
/.config/crossnote
/.config/dlv
/.config/gh
/.config/gh-dash
/.config/git
/.config/.dart-cli-completion
/.config/marimo
/.config/nvm
/.config/rclone
/.config/uv
/.config/wandb
/.config/wireshark
/.config/wezterm/_wezterm.lua
/.config/.claude
.DS_Store

# claude - only track settings, commands, statusline, commit-convention
/.claude/.credentials.json
/.claude/statsig
/.claude/sessions
/.claude/history.jsonl
/.claude/projects
/.claude/stats-cache.json
/.claude/debug
/.claude/cache
/.claude/downloads
/.claude/file-history
/.claude/ide
/.claude/paste-cache
/.claude/plans
/.claude/plugins
/.claude/session-env
/.claude/shell-snapshots
/.claude/skills
/.claude/.DS_Store
/.claude/mcp-needs-auth-cache.json
/.claude/backups
/.claude/memory
