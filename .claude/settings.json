{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(python3:*)",
      "Bash(ls:*)",
      "Bash(uv add:*)",
      "Bash(uv run python:*)",
      "WebSearch",
      "Bash(python:*)",
      "Bash(uv run pytest:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "WebFetch(domain:docs.astral.sh)",
      "Bash(uv lock:*)",
      "Bash(uv sync)",
      "Bash(uv pip install:*)",
      "Bash(uv pip freeze:*)",
      "Bash(uv pip list:*)",
      "Bash(ps:*)",
      "Bash(du:*)",
      "Bash(curl:*)",
      "Bash(tee:*)",
      "Bash(grep:*)",
      "Bash(sort:*)",
      "Bash(tmux list-sessions:*)",
      "Bash(tmux:*)",
      "Bash(git config:*)",
      "Bash(tail:*)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:github.com)",
      "Bash(gh api:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(mgrep:*)",
      "Bash(echo:*)",
      "Bash(uv pip show:*)",
      "Bash(pip install:*)",
      "Bash(pip show:*)",
      "Bash(source:*)",
      "Bash(chmod:*)",
      "Bash(codex review:*)",
      "Bash(codex exec:*)",
      "Bash(bash ~/.claude/codex-plan-review.sh:*)"
    ],
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-code-plugins": false,
    "claude-opus-4-5-migration@claude-code-plugins": false,
    "code-review@claude-code-plugins": true,
    "commit-commands@claude-code-plugins": true,
    "explanatory-output-style@claude-code-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "learning-output-style@claude-code-plugins": false,
    "plugin-dev@claude-code-plugins": false,
    "pr-review-toolkit@claude-code-plugins": true,
    "ralph-wiggum@claude-code-plugins": true,
    "security-guidance@claude-code-plugins": true,
    "example-skills@anthropic-agent-skills": false,
    "playwright-skill@playwright-skill": true,
    "everything-claude-code@everything-claude-code": false,
    "mgrep@Mixedbread-Grep": true,
    "hookify@claude-code-plugins": true,
    "skill-creator@claude-plugins-official": true
  },
  "language": "Japanese",
  "promptSuggestionEnabled": false,
  "autoUpdatesChannel": "latest",
  "voiceEnabled": false,
  "skipDangerousModePermissionPrompt": true
}
